{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "usernames": {
      ".read": true,
      "$handle": {
        ".write": "auth != null && (!data.exists() || data.val() === auth.uid) && newData.isString() && newData.val() === auth.uid",
        ".validate": "newData.isString() && newData.val() === auth.uid"
      }
    }
  }
}
